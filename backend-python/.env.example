# ─────────────────────────────────────────────────────────────────────────────
# sky-backend-python/.env.example
# Copiar como .env y llenar valores reales. NUNCA commitear .env
# ─────────────────────────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
DATABASE_URL=postgresql+asyncpg://postgres:xxx@db.xxx.supabase.co:5432/postgres

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Encryption — DEBE ser idéntica a la del backend Node
BANK_ENCRYPTION_KEY=tu_clave_hex_64_chars

# Redis
# IMPORTANTE: usar 127.0.0.1 en lugar de localhost en Windows. WSL2 puede
# tener wslrelay escuchando el puerto en IPv6 (::1) y ganar la resolución
# de "localhost" antes que Docker (0.0.0.0). En producción Railway no aplica.
REDIS_URL=redis://127.0.0.1:6379

# Server
PORT=8000
NODE_ENV=development
CORS_ORIGINS=https://app.skyfinanzas.com

# Cron
CRON_SECRET=openssl_rand_hex_32

# Scraping
CHROME_PATH=/usr/bin/chromium
BROWSER_POOL_SIZE=4
BCHILE_2FA_TIMEOUT_SEC=120

# Scheduler
SCHEDULER_BASE_INTERVAL_HOURS=1

# Fintoc (futuro — dejar vacío hasta activar)
FINTOC_SECRET_KEY=

# Rate limiting HTTP (Fase 11 — P2-3)
API_RATE_LIMIT_PER_MINUTE=60

# Observabilidad (vacío = abierto en dev; REQUERIDO en producción)
PROMETHEUS_SECRET=
# SENTRY_DSN ya existe arriba; requerido en producción

# Idempotency window
IDEMPOTENCY_TTL_SECONDS=86400

# Audit log salt — SHA-256(user_id + salt) → user_hash en public.audit_log
# Generar con: openssl rand -hex 32  (mismo nivel que BANK_ENCRYPTION_KEY)
# NUNCA rotar este salt en prod — invalida correlación histórica de eventos
AUDIT_LOG_SALT=

# Rotación de clave bancaria (solo durante período de rotación activa)
# BANK_ENCRYPTION_KEY_V2=nueva_clave_hex_64_chars
